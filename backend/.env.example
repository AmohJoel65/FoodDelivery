# ───────────────────────────────────────────────────
#  Joel's Kitchen — Backend .env (Render)
#  Copy this file to .env and fill in all values.
#  Never commit the real .env to Git.
# ───────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ── CORS ────────────────────────────────────────────
# Your Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://YOUR-APP.vercel.app

# ── JWT ─────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string

# ── Email (Gmail SMTP) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=joelamoh65@gmail.com
# Use a Gmail App Password — NOT your main Google password
# Create one at: https://myaccount.google.com/apppasswords
SMTP_PASS=your_16_char_gmail_app_password
SMTP_FROM="Joel's Kitchen <joelamoh65@gmail.com>"

# ── Restaurant Owner ────────────────────────────────
OWNER_EMAIL=joelamoh65@gmail.com
